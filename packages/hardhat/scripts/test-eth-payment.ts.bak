import { ethers } from "hardhat";
import { formatEther } from "viem";

const CLAWD_ROUTER = "0xA646A5843a3af5966206035917228bE6754Ae2e0";
const CLAWD_PRICING = "0xaca9733Cc19aD837899dc7D1170aF1d5367C332E";
const API_CREDITS = "0xc18fad39f72eBe5E54718D904C5012Da74594674";
const WETH = "0x4200000000000000000000000000000000000006";
const CLAWD = "0x9f86dB9fc6f7c9408e8Fda3Ff8ce4e78ac7a6b07";
const API_URL = "https://backend.zkllmapi.com";

async function main() {
  const [deployer] = await ethers.getSigners();
  console.log("Account:", deployer.address);

  const pricing = await ethers.getContractAt([
    "function creditPriceUSD() view returns(uint256)",
    "function getEthUsdPrice() view returns(uint256)",
  ], CLAWD_PRICING);
  const credits = await ethers.getContractAt([
    "function pricePerCredit() view returns(uint256)",
  ], API_CREDITS);

  const creditPriceUSD = await pricing.creditPriceUSD();
  const ethUsdPrice = await pricing.getEthUsdPrice();
  const pricePerCredit = await credits.pricePerCredit();

  console.log("creditPriceUSD:", formatEther(creditPriceUSD), "USD");
  console.log("ETH/USD:", formatEther(ethUsdPrice));
  console.log("pricePerCredit:", formatEther(pricePerCredit), "CLAWD");

  const ethCostExact = (creditPriceUSD * 10n**18n) / ethUsdPrice;
  const ethCostWithSlippage = ethCostExact * 115n / 100n; // 15% buffer
  const minCLAWDOut = pricePerCredit; // exact amount needed for 1 credit

  console.log("ETH exact:", formatEther(ethCostExact));
  console.log("ETH + 15% buffer:", formatEther(ethCostWithSlippage));
  console.log("minCLAWDOut:", formatEther(minCLAWDOut), "CLAWD");

  const bal = await ethers.provider.getBalance(deployer.address);
  console.log("ETH balance:", formatEther(bal));

  // Random commitment
  const randomBytes = new Uint8Array(31);
  crypto.getRandomValues(randomBytes);
  const commitment = BigInt("0x" + Array.from(randomBytes).map(b => b.toString(16).padStart(2,"0")).join(""));
  console.log("Commitment:", commitment.toString().slice(0,20)+"...");

  const router = await ethers.getContractAt("CLAWDRouter", CLAWD_ROUTER);

  // Simulate
  try {
    await router.buyWithETH.staticCall([commitment], minCLAWDOut, { value: ethCostWithSlippage });
    console.log("✅ Simulation passed");
  } catch(e: any) {
    console.log("❌ Simulation failed:", e.reason || e.shortMessage || e.message?.slice(0,200));
    return;
  }

  // Real tx
  console.log("\nSending real tx...");
  const tx = await router.buyWithETH([commitment], minCLAWDOut, { value: ethCostWithSlippage });
  console.log("Tx:", tx.hash);
  const receipt = await tx.wait();
  console.log("✅ Confirmed! Block:", receipt.blockNumber, "Gas:", receipt.gasUsed.toString());

  await new Promise(r => setTimeout(r, 5000));
  const health: any = await fetch(API_URL + "/health").then(r => r.json());
  console.log("Server treeSize:", health.treeSize, "validRoots:", health.validRoots);
  console.log("\n✅ ETH payment end-to-end TEST PASSED");
}
main().catch(e => { console.error(e.message); process.exit(1); });
